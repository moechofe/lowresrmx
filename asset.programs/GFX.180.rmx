'================== backed_new:
'width, height, back, new

tlb_6_redraw:
  bg 0 :bg source rom(3) :attr %100001
  bg fill 0,0 to 31,31 char 1
  bg copy 0,50,29,3 to 0,0
  bg copy 0,53,29,3 to 0,4
  bg copy 0,56,29,3 to 0,8
  gosub tlb_6_dim
  gosub tlb_6_size
  tlbrow=13-short*3 :tlbcol=26
  tlbraster1=24 :tlbraster2=48
  tlbrow1=4 :tlbrow2=7
  gosub tlb_setup
  return

tlb_6_data:
  data 4 :'number of widget
  data 2,8,7,10 :'wid=0 back
  data 8,0,12,2 :'wid=1 width
  data 21,0,26,2 :'wid=2 height
  data 8,8,12,10 :'wid=3 new

tlb_6_input:
  on wid goto tlb_6_back, tlb_6_width, tlb_6_height, tlb_6_new

tlb_6_back: 'wid=0
'cancel selection, go back to the previous toolbar
  call ungesture
  keyboard off
  tole=2 :gosub tlb_redraw
  return

tlb_6_width:
  tlb_6_x=8 :tlb_6_v=tlb_6_w
  gosub tlb_6_dim
