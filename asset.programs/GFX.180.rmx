manual_quit:
  copy rom(1),32 to $ff00
  cls
  wait vbl
  on raster call r2
  on vbl call v
  cnvchanged=-1 :fltchanged=-1 :tlbchanged=-1
  call ungesture
  goto backed

sub r2
'change what is shown on the screen using raster interrupt.
'the screen is divide in 3 parts for canvas, floating content and bottom toolbar. during the division a black bar of 4 pixels is shown ; used to do computation heavy things.

'TODO: oob

'canvas backed:
'  chr$8000..$8fff user's character (including chara for oob)
'  chr#0..255 user's character (including chara for oob)
'  pal#0..#7 user's palette (including color for oob)
'  bg#0 hidden
'  bg#1..#3 user's background
'  sprite hidden

'canvas filed:
'FIXME:  chr$8000..$842f ui font and ui button border
'FIXME:  chr#0..66 ui font and ui button border
'  chr#1 ui block
'  chr#67..131 ui files list font
'  chr#132..134 ui files list chara
'  pal#1,2 ui button
'  bg#0 ui file list
'  bg#0(32x0..63x63) file list
'  bg#1..3 hidden
'  sprite hidden

'floating charalist:
'  chr$8000..$8fff user's character (-3 charas for ui cursor)
'  chr#253..#255 or #64..66 ui cursor
'  pal#0 user's current palette
'  pal#4 ui cursor
'  bg#0 user's chara list
'  bg#0(0x32..15x47) user's chara list
'  bg#1..3 hidden
'  sprite#131..159 ui cursor

'TODO: fltui on kolorlist can always use the same chara

'floating kolorlist:
'  chr#0..3 ui color block
'  chr#253..#255 or #64..66 ui cursor
'  pal#0,1 64 colors list
'  pal#4 ui cursor
'  bg#0 64 colors list
'  bg#0(0x32..15x63) 64 colors list
'  bg#1..3 hidden
'  sprite#131..159 ui cursor

'TODO: I don't need prio flag because other layers are hidden

'toolbar all:
'  chr$8000..$83FF ui buttons and texts
'  chr#0..63 ui buttons and texts
'  pal#0 user's current palette
'  pal#1..3 ui buttons and texts
'  bg#0 ui buttons and texts
'  bg#0(0x0..31x31) ui buttons and texts
'  bg#1..3 hidden
'  short toolbar

'toolbar title:
'  pal#1 title bar

'toolbar backed_palette:
'  pal#4..7 user's 4 palette chooser

'toolbar palette_editor:
'  pal#4..7 user's 4 colors block

' ...


'''R_CANVAS

  on cane goto r_backed, r_filed, r_chared

r_backed:

if raster=shownh-2 then
  'gray border
  fill $ff00,32,3
  'copy first half of user's character
  pokew $ffa0,cara
  pokew $ffa2,$800
  pokew $ffa4,$8000
  dma copy
  exit sub

else if raster=shownh-1 then
  'copy second half of user's character
  pokew $ffa0,cara+$800
  pokew $ffa2,$800
  pokew $ffa4,$8800
  dma copy
  exit sub

else if raster=0 then
  'copy user's color
  copy pala,32 to $ff00
  'show user's layer, hide ui layer
  poke $ff32,%11100
  'copy oob out-of-bound character
  if oobe then copy rom(2)+1008,16 to $8000+oobc*16
  exit sub

else if fltshow then
  on floe goto r_charalist, r_kolorlist
else
  goto r_toolbar
end if

r_filed:

if raster=shownh-1 then
  pokew $ffa0,rom(2)
  pokew $ffa2,$860
  pokew $ffa4,$8000
  dma copy rom
  exit sub

else if raster=0 then
  'show ui layer
  poke $ff32,%10
  'place the file list at the right position
  scroll 0,32*8,fedscroll
  'copy the ui palette
  copy rom(1),12 to $ff00
  'hide the last button that appear at the top of the screen, because the 64 cells are used in height
  if fedscroll<0 then fill $ff00,12,3
  exit sub

else if raster+fedscroll=0 then
  'copy back the ui palette that was erase by the code above
  copy rom(1),12 to $ff00

else
  goto r_toolbar
end if

r_chared:

  if raster=0 then
    'show editor frame and user's edited chara
    poke $ff32,%10000
    'system 4,1
    'system 8,1
    'copy user's color
    copy pcla,32 to $ff00
    'editor frame color
    palette 3,peek(pcla),0,2,5
    'place the frame at the right position
    'scroll 3,-16,-16

    exit sub

else if fltshow then
  on floe goto r_charalist, r_kolorlist
else
  goto r_toolbar
end if

'''R_FLOATING

r_charalist:

if raster=fltcurr-4 then
  'black border
  poke $ff00,0
  'hide bgs, show sprite maybe
  poke $ff32,fltcursor
  'copy chara for the charalist cursor
  copy rom(2)+1024,48 to $8000+fltui*16
  'color for the ui cursor
  palette 4,,2,,0
  exit sub

else if raster=fltcurr-3 then
  'copy first half of user's character
  pokew $ffa0,cara
  pokew $ffa2,$800
  pokew $ffa4,$8000
  dma copy
  'copy chara for the charalist cursor
  copy rom(2)+1024,48 to $8000+fltui*16
  exit sub

else if raster=fltcurr-2 then
  'copy second half of user's character
  pokew $ffa0,cara+$800
  pokew $ffa2,$800
  pokew $ffa4,$8800
  dma copy
  'copy chara for the charalist cursor
  copy rom(2)+1024,48 to $8000+fltui*16
  exit sub

else if raster=fltcurr then
  'show bg 0, show sprite maybe, zoom bg 0
  poke $ff32,%100010+fltcursor
  'place the charalist at the right position
  scroll 0,lstx,-fltcurr+512+lsty
  'copy the user current selected palette, keep the backdrop color
  copy pala+pale*4,4 to $ff00
  exit sub

else
  goto r_toolbar
end if

r_kolorlist:

if raster=fltcurr-4 then
  'black border
  poke $ff00,0
  'hide bgs, show sprite maybe
  poke $ff32,%+fltcursor
  'copy chara for the charalist cursor
  copy rom(2)+1024,48 to $8000+fltui*16
  'copy chara for the color block
  copy rom(2),4*16 to $8000
  'color for the ui cursor
  palette 4,,2,,0
  exit sub

else if raster=fltcurr then
  'show bg 0, show sprite maybe, zoom bg 0
  poke $ff32,%100010+fltcursor
  'opaque bg 0
  system 1,1
  'place the charalist at the right position
  scroll 0,kolx,-fltcurr+512+koly
  'setup raster progress
  kolraster=((raster-fltcurr+koly)\24)*8
  'copy 4 next colors from the 64 list
  copy $9004+kolraster,8 to $ff00
  exit sub

else if raster>fltcurr and raster<tlbcurr-8 then
  if ((raster-fltcurr+koly) mod 24)=0 then
    'continue raster progress
    add kolraster,8
    'copy 4 next colors from the 64 list
    copy $9004+kolraster,8 to $ff00
  end if

else
  goto r_toolbar
end if

'''R_TOOLBAR

r_toolbar:
  'transparent bg 0
  'system 1,0

if raster=tlbcurr-8 then
  'black border
  poke $ff00,0
  'hide layers, show sprite maybe
  poke $ff32,fltcursor
  'copy ui character
  pokew $ffa2,$400
  pokew $ffa4,$8000
  pokew $ffa0,rom(2)
  dma copy rom
  exit sub

else if raster=tlbcurr-4 then
  'show bg 0, hide sprite, unzoom bg 0
  poke $ff32,%10
  'position toolbar
  scroll 0,tlbdrag,-tlbcurr
  'copy the ui palette
  ' copy rom(1),16 to $ff00
  'color and space for file toolbar title

  'gray border
  fill $ff00,32,3

  if tole=2 then
    palette 1,,,,0
    scroll 0,,scroll.y(0)+4
  else if tole=5 or tole=7 then
    'FIXME: this is not the patch I want, I have the same issue with the filer toolbar
    ' fill $ff00,8,3
    'colorize color chooser button
    palette 4,3,3,peek(pcla),fcccol(0)
    palette 5,3,3,peek(pcla+1),fcccol(1)
    palette 6,3,3,peek(pcla+2),fcccol(2)
    palette 7,3,3,peek(pcla+3),fcccol(3)
  end if
  exit sub

else if raster=tlbcurr then
  'copy the ui palette
  copy rom(1),16 to $ff00
  'color and space for file toolbar title
  if tole=2 then palette 1,,,,0
  exit sub

else if raster=tlbcurr+4 then
  'revert the color and space for file toolbar title
  if tole=2 then
    palette 1,,,,3
    scroll 0,,scroll.y(0)-4
  end if
  exit sub

else if raster=tlbcurr+8 then
  'copy user's current palette
  copy pala+pale*4,4 to $ff00
  'color and space for file toolbar title
  if tole=2 then palette 1,,,,5
  'copy user's palette 0 to 3
  if tole=3 then copy pala,16 to $ff10
  exit sub

else if raster=tlbcurr+31 then
  'copy user's palette 4 to 7
  if tole=3 then copy pala+16,16 to $ff10
  exit sub

else if raster=tlbcurr+tlbraster1 and short then
  'shorten the height of the bottom bar
  scroll 0,,scroll.y(0)+8
  exit sub

else if raster=tlbcurr+tlbraster2 and short then
  'shorten the height of the bottom bar
  scroll 0,,scroll.y(0)+8
  exit sub

end if
end sub


sub r
  if raster=0 then
    copy pala,32 to $ff00
    if cane=0 then
      poke $ff32,%11100
      call canoob
    else if cane=1 then
      bg view on 0
      bg view off 1
      bg view off 2
      bg view off 3
      scroll 0,32*8,fedscroll
      copy rom(1),32 to $ff00
    end if

  else if raster=tlbcurr-8 then
    'black border
    fill $ff00,8
    'palette 0,0,0,0,0
    'palette 1,0,0,0,0
    'hide user's layers, but keep sprite
    poke $ff32,%100011
    'copy ui character
    pokew $ffa2,$400
    pokew $ffa4,$8000
    pokew $ffa0,rom(2)
    dma copy rom

  else if raster=tlbcurr-4 then
    'gray border
    fill $ff00,16,3
    'copy back user's chara that was erased by the ui chara for the chara list cursor
    if cane=0 then copy cara+fltui*16,48 to $8000+fltui*16
    if tole=0 then copy cara+fltui*16,48 to $8000+fltui*16
    'unzoom bg
    system 5,0
    'show ui bg
    bg view on 0
    'place the bottom bar at the right position, for the filed title
    scroll 0,tlbdrag,-tlbcurr

  else if raster=tlbcurr then
    'place the bottom bar at the right position
    scroll 0,tlbdrag,-tlbcurr
    'copy the ui palette
    copy rom(1),32 to $ff00
    'todo: palette 3,,5,,3, I think I already change the color in ROM(1)
    'hide floating content cursor
    sprite view off
    ' 'copy the user current selected palette
    ' if cane=0 then copy pala+pala*4,4 to $ff00

  else if raster=shownh-2 and cane=0 then
    'gray border
    fill $ff00,32,3
    'copy first half of user's character
    pokew $ffa0,cara
    pokew $ffa2,$700
    pokew $ffa4,$8000
    dma copy

  else if raster=shownh-1 and cane=0 then
    'copy second half of user's character
    pokew $ffa0,cara+$700
    pokew $ffa2,$900
    pokew $ffa4,$8700
    dma copy
    'copy out-of-bound character
    if oobe then copy rom(2)+1008,16 to $8000+oobc*16

  else if raster=shownh-2 and cane=1 then
    pokew $ffa0,rom(2)
    pokew $ffa2,$1000
    pokew $ffa4,$8000
    dma copy rom

  end if

  'shorten the height of the bottom bar
  if (raster=tlbcurr+tlbraster1 or raster=tlbcurr+tlbraster2) and short then
    pokew $ff22,peekw($ff22)+8
  end if

  'show a title for the file toolbar
  if tole=2 then
    if raster=tlbcurr-4 then
      palette 1,,,,0
      pokew $ff22,peekw($ff22)+4
    else if raster=tlbcurr then
      palette 1,,,,0
      pokew $ff22,peekw($ff22)+4
    else if raster=tlbcurr+4 then
      palette 1,,,,3
      pokew $ff22,peekw($ff22)-4
    else if raster=tlbcurr+8 then
      palette 1,,,,5
    end if
  end if

  'hide the last filed button at the top of the screen
  if cane=1 and raster=0 and fedscroll<0 then fill $ff00,12,3
  if cane=1 and raster+fedscroll=0 then copy rom(1),12 to $ff00

  'floating content and toolbar specific raster handling
  if fltshow and floe>=0 then on floe gosub r_floe_0,r_floe_1
  on tole gosub r_tole_0, r_tole_, r_tole_ ,r_tole_3, r_tole_, r_tole_5, r_tole_

  exit sub

r_floe_0:
  if raster=fltcurr-4 then
    'black border
    palette 0,0,0,0,0
    ' bg view off 1

    ' bg view off 2
    ' bg view off 3
    ' trace bin$(peek($ff32),8)
    poke $ff32,0
    'copy back the user's chara that was overiddden by a ui chara for out-of-bound visiblity cells
    if oobe then copy cara+oobc*16,16 to $8000+oobc*16
    'copy chara for the charalist cursor
    copy rom(2)+64*16,48 to $8000+fltui*16
    'color for the ui cursor
    palette 4,,2,,0
    'copy chara for the kolorlist
    'if floe=1 then trace "fffffffff"
    'if floe=1 then copy rom(2),4*16 to $8000
    'show floating content cursor
    if fltcursor then sprite view on

  'draw the charalist in floating content part
  else if raster=fltcurr then
    'show ui bg
    bg view on 0
    'place the charalist at the right position
    scroll 0,lstx,-fltcurr+512+lsty
    'double the cells render size of the chara list
    system 5,1
    'make the background opaque
    system 1,1
    'copy the user current selected palette, keep the backdrop color
    'palette 0,peek(pala),,,
    'copy pala+pale*4+1,3 to $ff01
    copy pala+pale*4,4 to $ff00

  end if
  return

r_floe_1:
  if raster=fltcurr-4 then
    'black border
    palette 0,0,0,0,0
    poke $ff32,0
    'copy back the user's chara that was overiddden by a ui chara for out-of-bound visiblity cells
    'if oobe then copy cara+oobc*16,16 to $8000+oobc*16
    'copy chara for the charalist cursor
    copy rom(2)+64*16,48 to $8000+fltui*16
    'color for the ui cursor
    palette 4,,2,,0
    'copy chara for the kolorlist
    if floe=1 then copy rom(2),4*16 to $8000
    'show floating content cursor
    if fltcursor then sprite view on

  'draw the kolorlist in floating content part
  else if raster=fltcurr then
    'show ui bg
    bg view on 0
    'place the charalist at the right position
    scroll 0,kolx,-fltcurr+512+koly
    'double the cells render size of the chara list
    system 5,1
    'make the background opaque
    system 1,1
    'copy the user current selected palette, keep the backdrop color
    'palette 0,peek(pala),,,
    'copy pala+pale*4+1,3 to $ff01
    'copy pala+pale*4,4 to $ff00
    kolraster=((raster-fltcurr+koly)\24)*8
    copy $9004+kolraster,8 to $ff00

  else if raster>fltcurr and raster<tlbcurr-8 then
    if ((raster-fltcurr+koly) mod 24)=0 then
      add kolraster,8
      copy $9004+kolraster,8 to $ff00
    end if
  end if

  return

r_tole_: return

r_tole_0:
  'copy the user current selected palette
  if raster=tlbcurr+tlbraster1 then
    'trace hex$(pala+pale*4)
    copy pala+pale*4,4 to $ff00
    'fill $ff00,4,0
  'else if raster=tlbcurr+33 then
    'copy pala+pale*4,4 to $ff00
  end if
  return

r_tole_3:
  'colorize palette chooser button
  if raster=tlbcurr+8 then
    copy pala,16 to $ff10
  else if raster=tlbcurr+32 then
    copy pala+16,16 to $ff10
  end if
  return

r_tole_5:
  if raster=tlbcurr then
    'colorize color chooser button
    palette 4,,,peek(pcla),fcccol(0)
    palette 5,,,peek(pcla+1),fcccol(1)
    palette 6,,,peek(pcla+2),fcccol(2)
    palette 7,,,peek(pcla+3),fcccol(3)
  end if
  return

end sub

sub v
  if fccdir=0 then exit sub
  dec fccdelay
  if fccdelay>0 then exit sub
  fccdelay=6
  add fcccol(cole),fccdir
  if fcccol(cole)=46 or fcccol(cole)=54 then fccdir=-fccdir
  'compute if oob character can be copied
  call canoob
end sub



