  call ungesture
  return

tlb_6_height:
  tlb_6_x=22 :tlb_6_v=tlb_6_h
  gosub tlb_6_dim
  keyboard on
  call ungesture
  return

tlb_6_dim:
  bg 0 :attr 1
  bg fill 8,1 to 11,1 char 3
  bg fill 22,1 to 25,1 char 3
  text 8,1,str$(tlb_6_w)
  text 22,1,str$(tlb_6_h)
  return

tlb_6_size:
'display size and compute memory location
  bg 0 :bg source rom(3) :attr %100001
  bg copy 0,53,29,3 to 0,4
  pal 3
  s=tlb_6_w*tlb_6_h*2+4
  if s>$ffff then return
  text 12,5,hex$(s,4)
  if s<=0 then return
  addr=0
  call usrlook(s,0,wramstart,wramend,addr,fedlife)
  if addr>0 then
    text 18,5,hex$(addr,4)
    text 23,5,hex$(addr+s,4)
  end if
  return

tlb_6_edit:
'update width and height
  if tlb_6_x=0 then return
  if keyboard=0 then keyboard on
  k=-1 :k$=inkey$
  if k$<>"" then
    k=asc(k$)
    if k=8 and tlb_6_v>0 then
      tlb_6_v=int(tlb_6_v/10)
    else if k>=48 and k<=57 and tlb_6_v<99 then
      tlb_6_v=tlb_6_v*10+k-48
    end if
  end if
  bg 0 :attr 1
  bg fill tlb_6_x,1 to tlb_6_x+3,1 char 3
  v$=str$(tlb_6_v)
  text tlb_6_x,1,v$
  if tlb_6_x=8 then
    tlb_6_w=tlb_6_v
  else if tlb_6_x=22 then
    tlb_6_h=tlb_6_v
  end if
  gosub tlb_6_size
  if k=10 then
    tlb_6_x=0
    keyboard off
    return
  end if
  pal 1
  if (timer mod 50)>=20 then cell tlb_6_x+len(v$),1,62
  return

tlb_6_new:
'erase current file and create a new one
  'todo: check for changes not saved
  if addr<=0 then return
  if fedmode=0 then
    call usrnewbg(tlb_6_w,tlb_6_h,fedlife,bedlife)
    call stplayer(3,bedlife)
    call uselayer(3)
    call updlayer(laye)
    call ungesture
    keyboard off
    tole=0 :tlbchanged=-1
    floe=0 :fltshow=-1 :fltchanged=-1
    cnvchanged=-1
    bedoldt=1
  else :'if fedmode=1 then
    message "not implemented"
  end if
  return



'================ chared_first:
'toolbar to edit current user's characters
'4 colors button 4x(4)
'sheet, palette(4), zoom, undo
'char, layr, more(move/flip/rotate/copy/paste,sheeted), file

tlb_7_redraw:
  bg 0 :bg source rom(3) :pal 1
  bg fill 0,0 to 31,31 char 1
  bg copy 0,42,29,5 to 0,0
  bg copy 0,59,29,3 to 0,6
  bg copy 0,62,29,3 to 0,10
  tlbrow=15-short*3 :tlbcol=25
  tlbraster1=40 :tlbraster2=64
  tlbrow1=5 :tlbrow2=8
  gosub tlb_setup
  gosub flt_show
  return
tlb_7_data:
  data 8 :'number of widget
  data 2,0,7,4 :'wid=0 color 0
  data 9,0,14,4 :'wid=1 color 1
  data 15,0,20,4 :'wid=2 color 2
  data 21,0,26,4 :'wid=3 color 3
  data 8,10,13,12 :'wid=4 layer
  data 8,6,13,8 :'wid=5 palette
  data 15,6,20,8 :'wid=6 zoom
  data 21,10,26,12 :'wid=7 file
tlb_7_input:
  on wid goto tlb_7_color, tlb_7_color, tlb_7_color, tlb_7_color, tlb_7_backed, tlb_7_pal, tlb_7_zoom, tlb_7_file
tlb_7_backed: 'wid=4
'switch to backed editor
  if tapped then
    call ungesture
    cane=0 :cnvchanged=-1
    tole=0 :tlbchanged=-1
    floe=0 :fltchanged=-1
    neweditor=1
  end if
  return
tlb_7_color: 'wid=0..3
'select one of the 4 colors of the current palette
  if tapped then
    call usecolor(wid)
    ' gosub flt_show
  end if
  return
tlb_7_pal: 'wid=5
'show palette chooser
  if tapped then
    'todo: replace goto tlb_redraw by tlbchanged=-1
    call ungesture :tole=3 :goto tlb_redraw
  end if
  return
tlb_7_zoom: 'wid=6
'toogle zoom level
  if tapped then
    curr=min(fltcurr,tlbcurr)-8
    x=(cedx+shownw/2)/cedscale
    y=(cedy+curr/2)/cedscale
    cedzoom=not cedzoom
    cedscale=abs(cedzoom)+1
    cedx=x*cedscale-shownw/2
    cedy=y*cedscale-curr/2
    gosub ced_redraw
  end if
  restore tlb_7_data
  call repaintwidget(6,1,2,cedzoom)
  return
tlb_7_file: 'wid=7
'show the file menu
  if tapped then
    call ungesture
    fedlife=cedlife
    fedtitle$="characters"
    fedmode=2
    tole=2 :tlbchanged=-1
    fltshow=0
    gosub ced_limit
  end if
  return

