manual:
askmanual=0
cls
on raster off :on vbl off
sprite off
copy rom(1),32 to $ff00
copy rom(2),$1000 to $8000
bg source rom(3)
palette 0,2,8,8,2
palette 4,2,,,0
palette 5,2,62,63,3
palette 6,2,45,46,3
palette 7,2,1,17,61
shownw=0 :shownh=0
subject=-1
font 192
scrollx=0 :scrolly=0
do
  if shownw<>shown.w or shownh<>shown.h then
    shownw=shown.w :shownh=shown.h
    cls
    pal 1
    bg fill 0,0 to 63,0 char 1
    bg fill 0,0 to 0,63 char 1
    bg fill 63,0 to 63,63 char 1
    bg fill 0,63 to 63,63 char 1
    bg fill 21,0 to 21,63 char 1
    bg fill 42,0 to 42,63 char 1

    window 2,3,18,60,0
    pal 5
    print "gfx ";version$;" manual"
    print :print
    bg copy 2,6,6,3 to cursor.x+2,cursor.y+3
    bg copy 8,62,6,3 to cursor.x+8,cursor.y+3
    locate 0,cursor.y+4
    pal 0
    print "switch between layer and character editor"
    print :print
    pal 5
    print "subject:"
    print :print
    pal 0
    print "layer editor"
    bg fill cursor.x+2,cursor.y+3 to cursor.x+2+11,cursor.y+3 char 65
    print :print
    print "layer: draw"
    bg fill cursor.x+2,cursor.y+3 to cursor.x+2+10,cursor.y+3 char 65
    print :print
    print "layer: palette"
    bg fill cursor.x+2,cursor.y+3 to cursor.x+2+13,cursor.y+3 char 65
    print :print
    print "layer: more"
    bg fill cursor.x+2,cursor.y+3 to cursor.x+2+10,cursor.y+3 char 65
    print :print
    print "layer: file"
    bg fill cursor.x+2,cursor.y+3 to cursor.x+2+10,cursor.y+3 char 65
    print :print
    print "chara editor"
    bg fill cursor.x+2,cursor.y+3 to cursor.x+2+11,cursor.y+3 char 65
    print :print
    pal 6
    print "quit manual"
    bg fill cursor.x+2,cursor.y+3 to cursor.x+2+10,cursor.y+3 char 65

    if subject>=0 then on subject gosub subject_0, subject_1, subject_2, subject_3

    maxx=64*8-(shown.w-safe.l-safe.r)
    maxy=64*8-(shown.h-safe.t-safe.b)
  end if
  wait vbl
  if scrollx>=0 or scrolly>=0 then
    sx=scroll.x(0) :sy=scroll.y(0)
    dx=scrollx-sx :dy=scrolly-sy
    scrollx=-1: scrolly=-1
    if dx<>0 or dy<>0 then
      p=0
      for i=0 to 1 step 0.1
        p=ease(2,1,i)
        nx=clamp(sx+dx*p,0,maxx)
        ny=clamp(sy+dy*p,0,maxy)
        scroll 0,nx,ny
        wait vbl
      next i
    end if
  else if tap then
    px=touch.x :py=touch.y
    sx=scroll.x(0) :sy=scroll.y(0)
    cx=(touch.x+sx)\8 :cy=(touch.y+sy)\8
    trace cx,cy
    if cx>=2 and cy>=18 and cx<=13 and cy<=19 then gosub subject_0
    if cx>=2 and cy>=21 and cx<=12 and cy<=22 then gosub subject_1_1
    if cx>=2 and cy>=24 and cx<=15 and cy<=25 then gosub subject_1_2
    if cx>=2 and cy>=30 and cx<=12 and cy<=31 then gosub subject_3
    if cx>=2 and cy>=33 and cx<=13 and cy<=34 then gosub subject_4
    if cx>=2 and cy>=36 and cx<=12 and cy<=37 then goto manual_quit
  else if touch then
    dx=touch.x-px :dy=touch.y-py
    nx=clamp(sx-dx,0,maxx)
    ny=clamp(sy-dy,0,maxy)
    scroll 0,nx,ny
  end if
loop
end

